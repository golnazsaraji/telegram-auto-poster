BOT_TOKEN=123456:replace_with_your_telegram_bot_token
CHAT_ID=-1001234567890

# Telegram forum topic IDs
TOPIC_JOBS=1
TOPIC_CAREER=2
TOPIC_EVENTS=3
TOPIC_CHANNELS=4
TOPIC_SOFT_SKILLS=5

# Optional: enables official YouTube search instead of web-search fallback.
YOUTUBE_API_KEY=

# Automation settings
POST_INTERVAL_MINUTES=180
MAX_POSTS_PER_RUN=3
STATE_FILE=posted_items.json
LOG_LEVEL=INFO
HTTP_TIMEOUT_SECONDS=15
SSL_VERIFY=true
